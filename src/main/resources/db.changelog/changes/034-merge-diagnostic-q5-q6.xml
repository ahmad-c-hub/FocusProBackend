<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
         http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <!--
        Migration 034 — Merge diagnostic Q5 (reading comprehension) and Q6
        (re-read tracker) into a single combined passage task.

        Q5 is updated to the merged question with combined scoring:
          A = 10 pts (excellent comprehension + minimal re-reads)
          B =  6 pts (good comprehension + some re-reads)
          C =  2 pts (fair comprehension + several re-reads)
          D =  0 pts (poor comprehension + frequent re-reads)

        Q6 is disabled by setting display_order = 0 so it is excluded from
        the question list returned to clients while preserving existing
        diagnostic_response rows that reference it.

        Attention raw-score ceiling remains 25 pts:
          merged Q5 (max 10) + Q7 (5) + Q8 (5) + Q9 (5) = 25
        rawTotal ceiling remains 59, so the focus-score formula is unchanged.
    -->

    <changeSet id="034" author="focuspro">

        <!-- Update Q5 to merged reading + working-memory task -->
        <update tableName="diagnostic_question">
            <column name="question_text"
                    value="Combined reading and working memory assessment — read the passage carefully, tap each time you re-read a sentence, then answer the 3 questions that follow."/>
            <column name="option_a" value="Excellent comprehension and minimal re-reads"/>
            <column name="option_b" value="Good comprehension with some re-reads"/>
            <column name="option_c" value="Fair comprehension with several re-reads"/>
            <column name="option_d" value="Poor comprehension and frequent re-reads"/>
            <column name="points_a" valueNumeric="10"/>
            <column name="points_b" valueNumeric="6"/>
            <column name="points_c" valueNumeric="2"/>
            <column name="points_d" valueNumeric="0"/>
            <where>display_order = 5</where>
        </update>

        <!-- Disable Q6 (merged into Q5) — preserves FK refs in diagnostic_response -->
        <update tableName="diagnostic_question">
            <column name="display_order" valueNumeric="0"/>
            <where>display_order = 6</where>
        </update>

    </changeSet>

</databaseChangeLog>
