<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
          http://www.liquibase.org/xml/ns/dbchangelog
          https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.24.xsd">

    <changeSet id="025-create-daily-game-scores-table" author="abd">

        <createTable tableName="daily_game_scores">
            <column name="id" type="BIGINT">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="user_id" type="INT">
                <constraints nullable="false"/>
            </column>

            <column name="username" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>

            <column name="display_name" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>

            <column name="game_type" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>

            <column name="score" type="INT">
                <constraints nullable="false"/>
            </column>

            <column name="game_date" type="DATE">
                <constraints nullable="false"/>
            </column>

            <column name="submitted_at" type="TIMESTAMP"/>
        </createTable>

        <addAutoIncrement tableName="daily_game_scores"
                          columnName="id"
                          columnDataType="BIGINT"
                          generationType="IDENTITY"/>

        <addUniqueConstraint tableName="daily_game_scores"
                             columnNames="user_id, game_date"
                             constraintName="uq_daily_game_user_date"/>

        <rollback>
            <dropTable tableName="daily_game_scores"/>
        </rollback>

    </changeSet>

</databaseChangeLog>
