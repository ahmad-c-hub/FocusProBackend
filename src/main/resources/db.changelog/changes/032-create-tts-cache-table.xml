<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
          http://www.liquibase.org/xml/ns/dbchangelog
          https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.24.xsd">

    <changeSet id="032-create-tts-cache-table" author="abd">

        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="tts_cache"/></not>
        </preConditions>

        <createTable tableName="tts_cache">
            <column name="text_hash" type="INT">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="audio_bytes" type="BYTEA">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <rollback>
            <dropTable tableName="tts_cache"/>
        </rollback>

    </changeSet>

</databaseChangeLog>
